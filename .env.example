# Environment Variables for Climate Data ETL Pipeline
# Copy to .env and fill in actual secrets before running `docker compose up`.

# ==================== Authentication ====================
# Simple username+password gate for the Vue SPA (token-based session).
# Set either AUTH_PASSWORD_HASH (preferred, PBKDF2-SHA256) or AUTH_PASSWORD
# (plaintext fallback). Both unset → /auth/login returns 503, every
# protected endpoint returns 503 too unless AUTH_ALLOW_ANONYMOUS=1.
AUTH_USERNAME=admin
# When AUTH_PASSWORD_HASH is set, AUTH_PASSWORD is ignored. Prefer the hash.
AUTH_PASSWORD=CHANGE_ME_BEFORE_DEPLOYING
# Generate with: python scripts/hash_password.py
# The hash contains $ characters — wrap in single quotes so docker-compose
# doesn't treat them as variable substitutions.
# AUTH_PASSWORD_HASH='$argon2id$v=19$...'

# JWT signing secret — any random 64+ char string. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# If unset, the code falls back to AUTH_PASSWORD_HASH/AUTH_PASSWORD, which
# means tokens rotate every time you change the password.
# JWT_SECRET_KEY='...'

# Rate-limit for /auth/login (per source IP). Defaults: 10 failures in 900 s → 429.
# AUTH_LOGIN_MAX_FAILURES=10
# AUTH_LOGIN_WINDOW_SECONDS=900

# Opt-in to unauthenticated access. Use only in CI / local smoke tests.
# Any value other than 1/true/yes is treated as off.
# AUTH_ALLOW_ANONYMOUS=0

# ==================== LLM Backend Selection ====================
# Set to 'openrouter' or 'ollama'. If unset: auto-detect
# (OpenRouter when OPENROUTER_API_KEY is present, Ollama otherwise).
# LLM_BACKEND=

# ==================== OpenRouter (cloud LLM) ====================
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ==================== Unstructured Documents Collection ====================
# Separate Qdrant collection for PDF/DOCX/PPTX/MD/TXT documents.
# Uses the rag-mendelu AgenticRAG pipeline (LangGraph + Ollama) for queries.
DOCS_COLLECTION_NAME=climate_data_documents

# ==================== Ollama (local LLM) ====================
# Ollama must be running on the host machine (not inside Docker).
#   Local dev (no Docker):      http://localhost:11434
#   Inside Docker container:    http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=ministral-3:3b

# ==================== Vector Database ====================
QDRANT_HOST=qdrant
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# ==================== Application database ====================
# PostgreSQL connection URL used by web_api and Dagster ops for the
# `climate_app` database (managed sources, schedules, processing_runs).
# The dagster-postgres container also stores Dagster metadata in the
# separate `dagster` database.
APP_DATABASE_URL=postgresql://dagster:dagster@dagster-postgres:5432/climate_app

# ==================== Dagster ====================
# Path inside the container where dagster_home lives (bind-mounted volume).
DAGSTER_HOME=/opt/dagster/dagster_home

# ==================== Portal credentials (optional) ====================
# New CDS API (2024+): https://cds.climate.copernicus.eu/how-to-api
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=

# NASA Earthdata: https://urs.earthdata.nasa.gov/
# NASA_EARTHDATA_TOKEN=
# NASA_EARTHDATA_USER=
# NASA_EARTHDATA_PASSWORD=

# Copernicus Marine (CMEMS): https://data.marine.copernicus.eu/
# CMEMS_USERNAME=
# CMEMS_PASSWORD=

# Other portal tokens used by specific catalog entries (optional)
# EIDC_USERNAME=
# EIDC_PASSWORD=
# NCAR_RDA_TOKEN=
# CEDA_TOKEN=

# ==================== Data Directories ====================
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOGS_DIR=logs

# ==================== Catalog Configuration ====================
CATALOG_EXCEL_PATH=data/Kopie souboru D1.1.xlsx

# ==================== Pipeline Configuration ====================
PIPELINE_CONFIG=config/pipeline_config.yaml

# ==================== Logging Configuration ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== Processing Options ====================
NORMALIZE_DATA=true
AGGREGATION_METHOD=mean
EXPORT_FORMATS=netcdf,parquet

# ==================== Performance Settings ====================
CHUNK_SIZE=1000
MAX_WORKERS=4
MEMORY_LIMIT_GB=8

# Upload size cap (MB) for POST /sources/upload. Default 5000 (~5 GB) — bump
# this if your climate files are larger, or lower it to constrain disk use.
UPLOAD_MAX_MB=5000

# ==================== Dagster-postgres container ====================
# Credentials for the postgres container itself (used by init-db.sh + Dagster).
POSTGRES_USER=dagster
POSTGRES_PASSWORD=dagster
POSTGRES_DB=dagster

# ==================== Development Options ====================
DEBUG_MODE=false
ENABLE_PROFILING=false
