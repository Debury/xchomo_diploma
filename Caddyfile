# Caddyfile for ClimateData AI Assistant
# Automatic HTTPS with Let's Encrypt in production; HTTP-only when used locally.

(security_headers) {
	header {
		# Force HTTPS for one year. Browsers will refuse plain-HTTP to this host.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Disallow MIME sniffing and embedding in frames.
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Restrict which origins can load resources. 'unsafe-inline' is required
		# because the Vite build ships inline styles/scripts for the SPA bundle.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		# Remove the Server header so we don't advertise Caddy version.
		-Server
	}
}

climaterag.online {
	import security_headers
	reverse_proxy web-api:8000 {
		header_up Host {host}
		header_up X-Real-IP {remote}
	}
}

# HTTP to HTTPS redirect for the production host.
http://climaterag.online {
	redir https://climaterag.online{uri} permanent
}
